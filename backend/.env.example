# ─── Environment ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5050

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Backend public URL (HTTPS for Meta Flow + webhook). Use ngrok in dev.
BACKEND_URL=
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.example.mongodb.net/vijya_hospital

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
JWT_SECRET=change-me

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_VERIFY_TOKEN=vijya_hospital_verify
META_GRAPH_VERSION=v22.0

# Auto-populated by `npm run flow:setup`
WHATSAPP_FLOW_ID=
WHATSAPP_FLOW_STATUS=
FLOW_PRIVATE_KEY=
FLOW_PUBLIC_KEY=

# Cloudinary (logos/icons/banners only — never for generated PDFs)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=vijya_hospital

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_KEY={}

# Redis (optional)
REDIS_URL=

# ngrok
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Hospital fallback config (overridden by Settings collection)
HOSPITAL_NAME=Vijya Hospital
HOSPITAL_PHONE=
HOSPITAL_ADDRESS=
HOSPITAL_LOCATION_LAT=
HOSPITAL_LOCATION_LNG=
HOSPITAL_WEBSITE=

# ─── Super Admin (platform owner) ──────────────────────────────────────────
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=admin@123
SUPERADMIN_EMAIL=

# ─── Razorpay (platform/super-admin credentials — used for admin plan purchases) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── SMTP (for emailing dynamically generated subscription invoices) ──────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Vijya Hospital <no-reply@vijyahospital.com>
